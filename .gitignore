# Environment — never commit secrets
.env

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Runtime data (SQLite databases, uploads)
data/
*.db

# Qdrant local lock file (runtime-only, must not be shipped)
qdrant_db/.lock

# Source PDFs/large docs — only the built qdrant_db is needed at runtime
*.pdf

# Large ML model cache
.cache/
sentence_transformers/

# IDE
.vscode/
.idea/
